datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id          Int     @id @default(autoincrement())
  email       String  @unique
  legacyToken String?
}

model AuditLog {
  id      Int    @id @default(autoincrement())
  payload String
}
